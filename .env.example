# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
# Path to the SQLite database file. On a free cloud host with a persistent
# disk, point this at the mounted volume (e.g. /var/data/omc.db).
DATABASE_PATH=omc.db
# Public base URL of the site (used to build magic-link login URLs in emails).
BASE_URL=http://127.0.0.1:5000

# --- Access codes / first director ---
# The email addresses listed here are automatically granted the "director"
# (admin) role the first time they log in. Comma-separated.
DIRECTOR_EMAILS=daniels@zenity.io

# --- Email (magic links) ---
# If SMTP is not configured, magic-link URLs are printed to the server log
# instead of emailed (fine for local/lab testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=omc-portal@example.com

# --- AI agenda analysis ---
# AI_ENABLED=1 turns on AI analysis. If the provider is unreachable or no key
# is set, the app falls back to a simple keyword extractor so submissions
# always work.
AI_ENABLED=1
# Provider: groq | gemini | ollama
AI_PROVIDER=groq

# Groq (free, no credit card): get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free tier): get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local Ollama (only used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
